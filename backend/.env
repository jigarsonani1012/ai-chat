APP_NAME=AI Chatbot SaaS
APP_ENV=development
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=sqlite:///./ai_chatbot_saas.db
REDIS_URL=redis://localhost:6379/0
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
VECTOR_STORE=faiss
VECTOR_STORE_PATH=./storage/vector_indexes
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_SIZE_MB=25
RATE_LIMIT_PER_MINUTE=60
QUEUE_BACKEND=dramatiq
ENABLE_SYNC_TASK_FALLBACK=true
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
PUBLIC_WIDGET_ORIGIN=http://localhost:5173
ADMIN_DASHBOARD_ORIGIN=http://localhost:5174
ALLOWED_HOSTS=["*"]
